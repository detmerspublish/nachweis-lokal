{
  "name": "@codefabrik/nachweis-lokal",
  "version": "0.7.5",
  "private": true,
  "license": "GPL-3.0-only",
  "type": "module",
  "main": "electron/main.cjs",
  "description": "Nachweis Lokal — Pruefprotokolle, Checklisten und Nachweise (Electron + Svelte Desktop-App)",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:1423 && cross-env VITE_DEV_SERVER_URL=http://localhost:1423 electron .\"",
    "electron:build": "vite build && electron-builder --publish never",
    "test": "node --test tests/test_*.js"
  },
  "dependencies": {
    "@codefabrik/app-shared": "workspace:*",
    "@codefabrik/electron-platform": "workspace:*",
    "@codefabrik/shared": "workspace:*",
    "@codefabrik/ui-shared": "workspace:*",
    "better-sqlite3": "^11.0.0",
    "pdfmake": "^0.2.0",
    "qrcode-generator": "^2.0.4"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "sql.js": "^1.14.1",
    "svelte": "^5.0.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "de.detmers-publish.nachweis-lokal",
    "productName": "Nachweis Lokal",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "app.config.cjs",
      "assets/icons/**/*",
      "node_modules/@codefabrik/electron-platform/**/*",
      "node_modules/@codefabrik/shared/**/*",
      "node_modules/@codefabrik/app-shared/**/*",
      "node_modules/@codefabrik/ui-shared/**/*",
      "node_modules/better-sqlite3/**/*",
      "mobile/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icons/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icons/icon.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/icons/icon.png",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icons/icon.ico"
    },
    "directories": {
      "output": "release"
    }
  }
}
